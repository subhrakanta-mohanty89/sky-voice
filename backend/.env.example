# =============================================================================
#  Sky AI — Customer Support Backend  (Twilio)
#  Copy this file to `.env` and fill in the values from your Twilio console.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — Twilio account credentials
# -----------------------------------------------------------------------------
# Find these on the Twilio Console dashboard: https://console.twilio.com
# ACCOUNT_SID starts with "AC..." and AUTH_TOKEN is shown next to it.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# -----------------------------------------------------------------------------
# REQUIRED — API Key (used to mint short-lived Voice SDK access tokens)
# -----------------------------------------------------------------------------
# Create at: https://console.twilio.com/us1/account/keys-credentials/api-keys
# Click "Create API Key" → keep type = Standard.
# After creation, the SECRET is shown only ONCE — save it here immediately.
# API_KEY_SID starts with "SK..."
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your_api_key_secret_here

# -----------------------------------------------------------------------------
# REQUIRED — TwiML Application SID (for browser/mobile softphone outbound calls)
# -----------------------------------------------------------------------------
# Create at: https://console.twilio.com/us1/develop/voice/manage/twiml-apps
# Click "Create new TwiML App". Name it "Sky AI Softphone".
# Set the **Voice → Request URL** to:
#     {PUBLIC_BASE_URL}/twilio/voice/outgoing      (HTTP POST)
# After creation, copy the App SID below. It starts with "AP..."
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# REQUIRED — The customer-support phone number you purchased from Twilio
# -----------------------------------------------------------------------------
# Use E.164 format with leading "+" and country code, e.g. +14155550100
# Then in the Twilio console open this number's settings and configure:
#   Voice → "A Call Comes In" → Webhook → POST → {PUBLIC_BASE_URL}/twilio/voice/incoming
#   Voice → "Call Status Changes" (optional) → POST → {PUBLIC_BASE_URL}/twilio/voice/status
TWILIO_CALLER_ID=+1xxxxxxxxxx


PUBLIC_BASE_URL=https://your-public-url.ngrok-free.app

# -----------------------------------------------------------------------------
# OPTIONAL — Server settings
# -----------------------------------------------------------------------------
PORT=5050
HOST=0.0.0.0
FLASK_ENV=development
LOG_LEVEL=INFO

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,https://skyvoice.web.app,https://skyvoice.firebaseapp.com

APP_SECRET_KEY=change-me-to-a-long-random-string

INCOMING_RING_TIMEOUT=25

FALLBACK_FORWARD_NUMBER=

# Hold music URL (any public-facing MP3/WAV). Twilio's free sample is the default.
HOLD_MUSIC_URL=https://com.twilio.sounds.music.s3.amazonaws.com/MARKOVICHAMP-Borghestral.mp3

RECORD_CALLS=false

VALIDATE_TWILIO_SIGNATURE=true

# -----------------------------------------------------------------------------
# OPTIONAL — Mailgun (transactional email: signup confirmations, password resets, etc.)
# -----------------------------------------------------------------------------
# Get values from https://app.mailgun.com/app/account/security/api_keys
# MAILGUN_API_KEY is a secret — never commit a real key.
MAILGUN_DOMAIN=mg.example.com
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAILGUN_BASE_URL=https://api.mailgun.net/v3
MAIL_FROM=Sky Voice AI <no-reply@mg.example.com>
